# For MSYS2
# Maintainer: ManOfInfinity <https://github.com/ManOfInfinity>

pkgbase=infidl-git
pkgname=("$pkgbase")
pkgver=v2.0
pkgrel=1
url="https://github.com/ManOfInfinity/infidl"
pkgdesc="A CLI downloader optimized for speed and early preview, based on libcurl."
arch=('i686' 'x86_64')
license=('AGPL')
depends=('msys2-runtime' 'libcurl' 'libevent')
makedepends=('msys2-runtime-devel' 'libcurl-devel' 'libevent-devel' 'python3' 'git' 'asciidoc')
source=($pkgbase::git://github.com/ManOfInfinity/infidl.git)
md5sums=('SKIP')

pkgver() {
  cd "$srcdir/$pkgbase"
  infidl_ver="$(git describe --tags --long --dirty)"
  echo ${infidl_ver//-/.}
}

build() {
  cd "$srcdir/$pkgbase"

  CC=/usr/bin/gcc \
  PKGCONFIG=/usr/bin/pkg-config \
  python3 waf configure --prefix="/usr"

  python3 waf build
}

package_infidl-git() {
  cd "$srcdir/$pkgname"
  python3 waf install --destdir="$pkgdir"
}
